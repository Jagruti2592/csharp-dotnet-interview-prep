@model Category



<form method="post">

    <div class="row pb-2">
        <h2 class="text-primary">Edit Category</h2>
        <hr />
    </div>
    <div asp-validation-summary="All" class="text-bg-warning"></div>
    <div class="mb-3 row p-1">
        <label asp-for="Name" class="p-0"> </label>
        <input asp-for="Name" disabled class="form-control" />
       
    </div>
    <div class="mb-3 row p-1">
        <label asp-for="DisplayOrder" class="p-1"> </label>
        <input asp-for="DisplayOrder" disabled class="form-control" />
       
    </div>

    <div class="row">
        <div class="col-6 col-md-3">
            <button type="submit" class="btn btn-primary form-control">Delete</button>
        </div>
        <div class="col-6 col-md-3">
            <a asp-asp-controller="Category" asp-action="Index" class="btn btn-outline-secondary border-2 form-control">Back to List</a>
        </div>
    </div>



</form>

@section Scripts {
    @{
        <partial name="_ValidationScriptsPartial" />
    }
}

